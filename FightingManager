invoke.OnServerInvoke = function(player, field)
	local profile = profiles.getprofile(player.UserId)
	local char:Model = player.Character
	local humanoid = char.Humanoid
	local area = info.fighting.enemystats[field]
	local weapon = profile["Currentweapon"] or "Basic Sword"
	local choice = math.random(1, 100)
	local enemyres
	for i,v in ipairs(indexedares[field]) do
		local rarity = enemstats[field][v] and enemstats[field][v]["rarity"]
		if not rarity then return end
		if choice <= rarity then enemyres = v break end
	end
	if not enemyres then return end
	profiles.updateprofile(player.UserId, "Fighting", true)
	local hasach = profile["Achievsets"]["Fighting"] or {}
	humanoid.MaxHealth = 15 + ((hasach["easy"] and 5) or 0)
	humanoid.Health = humanoid.MaxHealth
	char:PivotTo(CFrame.new(workspace:WaitForChild("PlayerPos").Position)*CFrame.Angles(0, math.rad(-13),0))
	profiles.updateprofile(player.UserId, "CurrentEnemy", enemyres)
	print(profiles.getprofile(player.UserId)["CurrentEnemy"])
	humanoid.Died:Connect(function()
		profiles.updateprofile(player.UserId, "Fighting", false)
	end)
	dodamage(player, info.fighting.weaponstats[weapon], enemyres, field)
	return
end
