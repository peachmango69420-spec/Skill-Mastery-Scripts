local function reward(player: Player, enemy: string)
	local profile = profiles.getprofile(player.UserId)
	profile["Kills"] = profile["Kills"] or {}
	profile["Kills"][enemy] = (profile["Kills"][enemy] or 0) + 1
	local mult = 1
	local hasach = profile["Achievsets"]["Fighting"] or {}
	if hasach["medium"] then local coinflip = math.random(1,2) if coinflip == 2 then mult *= 2 end end
	local gotall = true
	for name, _ in info.fighting.enemystats.Fields do
		if not profile["Kills"][name] then gotall = false end
	end
	if gotall then profiles.awardAchievement(player, {Skill = "Fighting", Diff = "easy", Index = 1}) end
	local rewardsinfo = info.fighting.enemyrewards[enemy]
	local xpforenemy = info.fighting.enemyxpbonus[enemy]
	local rewards = {}
	for i, rewardtable in ipairs(rewardsinfo) do
		local chance = (math.random() <= rewardtable.chance)
		if chance then 
			local totalamount = math.random(rewardtable.min, rewardtable.max)
			rewards[rewardtable.reward] = totalamount
			profiles.updateprofile(player.UserId, rewardtable.reward, totalamount)
		end
	end
	if rewards["Cheese"]  then profiles.progAchieve(player, {Cat = "Fighting", Diff = "easy", Index = 2}, rewards["Cheese"])
	elseif rewards["Bones"] then profiles.progAchieve(player, {Cat = "Fighting", Diff = "medium", Index = 1}, rewards["Bones"])
	elseif rewards["Feathers"] then profiles.progAchieve(player, {Cat = "Fighting", Diff = "medium", Index = 3}, rewards["Feathers"])
	end
	if enemy == "Wasp" and profile["CurrentSword"] and profile["CurrentSword"] == 0 then
		profiles.awardAchievement(player, {Skill = "Fighting", Diff = "medium", Index = 2})
	end
	if rewards["Wasp Wings"] then
		profiles.awardAchievement(player, {Skill = "Fighting", Diff = "easy", Index = 3})
	end
	profiles.giveXP(player, "Fighting", xpforenemy)
	rewards["Fighting XP"] = xpforenemy
	rep.Update.Rewards:FireClient(player, rewards, enemy)
	player.Character:PivotTo(workspace.Trainer:GetPivot())
	player.Character:PivotTo(player.Character:GetPivot()*CFrame.new(2,0,0))
end
