local function withRetries(fn, maxAttempts)
	local delay = 0.5
	for attempt = 1, maxAttempts do
		local ok, resultOrErr = pcall(fn)
		if ok then
			return true, resultOrErr
		end
		task.wait(delay + math.random() * 0.2)
		delay = math.min(delay * 2, 4)
	end
	return false, "failed after retries"
end
local profiles = {}
local DataStoreWrapper = {}
function DataStoreWrapper.Deserialize(profile) 
		local raw = {}
		for key, value in pairs(profile) do
			if key ~= "schemaVersion" then
			raw[key] = value end
		if type(value) == "userdata" then
			print("Userdata! " , key)
			raw[key] = value.Name
		end
		end
		raw["dirty"] = false
		raw["lastonline"] = os.time()
		raw["OfflineGains"] = {
			["Stone"] = {rate = 0.01, mult = 1}
		}
		return raw
	end
function DataStoreWrapper.Serialize(profile) 
		local raw = {}
		for key, value in pairs(profile) do
			raw[key] = value
		end
		raw["dirty"] = true
		raw["schemaVersion"] = profile.schemaVersion
		return raw
	end 
function DataStoreWrapper.GetRaw(storeName, key)
		local currentstore = dss:GetDataStore(storeName)
		local ok, value = withRetries(function() return currentstore:GetAsync(key) end, 3)
		if not ok then return nil, value end
		--value["ActiveDialogues"] = {}
		--value["EndersClaimed"] = {}
		return value
	end
function DataStoreWrapper.SetRaw(storeName, key, value, dirty)
		local currentstore = dss:GetDataStore(storeName)
		local ok, err = withRetries(function() return currentstore:SetAsync(key,value) end, 3)
		if ok then print("Successfully saved!") else print("Failed to save! Error: ", err) end
	if not dirty then profiles[key] = nil end
		return ok, err
	end
function DataStoreWrapper.DefaultProfile(player)
		local descendants = player:GetDescendants()
		local default = profiles[player.UserId] or {}
		local toolcountz = {}
		for _, child in descendants do
			if string.find((child.ClassName), "Value") then
				default[child.Name] = child.Value
		end 
		default["Playlist"] = default["Playlist"] or require(game.ReplicatedStorage.Modules.DesignInfo).defaultmusic
		for _, name in ipairs(storetables) do
		default[name] = default[name] or {}
		end
		local plot = game.CollectionService:GetTagged(player.UserId)[1]
		for i = 1, PLOT_Nums do
			default["Plotstats"][i] = default["Plotstats"][i] or {Growfinish = 0, Currentcrop = "none", Shiny = false, Growing = false}
		end
		print("Profile now: ",default)
		return default
	end end
function DataStoreWrapper.setprofile(name, arg)
		profiles[name] = arg
	end
function DataStoreWrapper.updateprofile(userkey, key1, newval, key2)
		local profile = profiles[userkey]
		if profile and not profile[key1] then 
			profiles[userkey][key1] = newval return end
		if key2 and profile[key1] and not profile[key1][key2] then profiles[userkey][key1][key2] = newval return
		elseif key2 and profile[key1] then
			if type(newval) == "number" then
				profiles[userkey][key1][key2] += newval
			elseif type(newval) == "table" then
				profiles[userkey][key1][key2] = newval
			elseif newval == nil then
				profiles[userkey][key1][key2] = nil
			end
			return end
		if type(newval) == "number" and type(profile[key1]) == "number" then profiles[userkey][key1] += newval
		elseif type(newval) == "table" then profiles[userkey][key1] = newval
		elseif type(newval) == "boolean" or type(newval) == "string" then profiles[userkey][key1] = newval
		end
		return
	end
