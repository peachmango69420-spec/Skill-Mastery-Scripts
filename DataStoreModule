function DataStoreWrapper.awardAchievement(player:Player, achievementinfo)
		local profile = profiles[player.UserId]
		local catname = achievementinfo["Skill"] or "None"
		local diff = achievementinfo["Diff"] or "easy"
		local index = tonumber(achievementinfo["Index"] or 1) or 1
		local achieve = gameinf.achievements[catname][diff][index]
		if not profile["Achievs"][catname] then profile["Achievs"][catname] = {easy = {}, medium = {}, hard = {}} end
		local profexist = profile["Achievs"][catname][diff][index]
		if not profexist then
		profile["Achievs"][catname][diff][index] = true
			game.ReplicatedStorage.Update.NotifyAchiev:FireClient(player, {Cat = catname, Diff = diff, Index = index}) 
			print("Got achievement!", profile, catname, diff, index)
		local allAchieves = true
		for i = 1, #gameinf.achievements[catname][diff] do
			if not profile["Achievs"][catname][diff][i] then
				allAchieves = false
			end
		end	
		if allAchieves then
			print(player.Name,"Has completed the",catname,diff,"Set!")
			if not profile["Achievsets"][catname] then profile["Achievsets"][catname] = {} end
			profile["Achievsets"][catname][diff] = true
		end
		end
	end
function DataStoreWrapper.progAchieve(player, achinfo, amount)
		local profile = profiles[player.UserId]
		local cat = achinfo["Cat"]
		local diff = achinfo["Diff"]
		local ind = achinfo["Index"]
		local info = gameinf.achievements[cat][diff][ind]
		local progress = profile["Achievprogs"][info.goal]
        profile["Achievprogs"][info.goal] = ((progress or 0) + amount) or 0
	    if profile["Achievprogs"][info.goal] >= info.goalnum then 
			DataStoreWrapper.awardAchievement(player, {Skill = cat, Diff = diff, Index = ind})
		end
	end
function DataStoreWrapper.giveXP(player, skillname, amount)
	local mult = mat.xpmultcalc(player, amount)
	local profile = profiles[player.UserId]
	profile[skillname.."_XP"] += mult
	player.SkillXP:FindFirstChild(skillname.."_XP").Value += mult
	local newlevel = mat.levelcalc(player, skillname, profile[skillname .. "_XP"])[1]
	profile[skillname.."_Level"] = newlevel
end
function DataStoreWrapper.harvestcrop(plr, number, crop, model)
	local profile = profiles[plr.UserId]
	local plotstats = profile["Plotstats"][number]
	local plot = model.Parent
	local sparkles = plot.Soil:FindFirstChildWhichIsA("Sparkles")
	local info = gameinf.farming.seeds[crop or "Mushroom"]
	local minharvest = info.minharvest
	local maxharvest = info.maxharvest
	local xpreward = info.xpreward
	local mult = plotstats["Shiny"] and 10 or 1
	local tags = plot.Parent:GetTags()
	if tags[1] == tostring(plr.UserId) then
		local harvestcount = math.random(minharvest * mult, maxharvest * mult)
		profile[crop.."s"] = (profile[crop.."s"] or 0) + harvestcount
		DataStoreWrapper.giveXP(plr, "Farming", xpreward)
		plotstats["Currentcrop"] = "none"
		plotstats["Growing"] = false
		plotstats["Shiny"] = false
		plot.GuiPart.BillboardGui.Label.Text = "None"
		local loot = game.ReplicatedStorage.UiStuff.Loot:Clone()
		local ui = plot.GuiPart.BillboardGui
		loot.Parent = ui
		ui.Label.Visible = false
		ui.StudsOffset = Vector3.new(0, -3, 0)
		game.Debris:AddItem(loot, 1.2)
		loot.Text = "+"..harvestcount .. " " .. crop
		game.TweenService:Create(ui, TweenInfo.new(1.2), {StudsOffset = Vector3.new(0, 1, 0)}):Play()
		model:Destroy()
		task.wait(0.7)
		game.TweenService:Create(loot, TweenInfo.new(0.5), {TextTransparency = 1}):Play()
		task.wait(0.5)
		ui.Label.Visible = true
		ui.StudsOffset = Vector3.new(0, 0, 0)
		if sparkles then sparkles:Destroy() end
	end
