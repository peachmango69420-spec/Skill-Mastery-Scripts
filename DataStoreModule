function DataStoreWrapper.additem(player, itemname, amount, tabletolookinto)
	local pack = player.Backpack
	local start = player.StarterGear
	local profile = profiles[player.UserId]
	local stats = player.stats
	local leaderstats = player.leaderstats
	local statsitem = stats:FindFirstChild(itemname) or leaderstats:FindFirstChild(itemname)
	local proftable = profile[tabletolookinto] or {}
	local profileitem = profile[itemname] or proftable[itemname]
	local backtool = game.ServerStorage.Tools:FindFirstChild(itemname) --player.Backpack:FindFirstChild(itemname)
	local querytag = '[$ToolName = "'..itemname..'"]'
	local packtool = pack:QueryDescendants(querytag)[1] or player.Character:FindFirstChildWhichIsA("Tool")
	if packtool and packtool:GetAttribute("ToolName") ~= itemname then packtool = nil end
	local startool = start:QueryDescendants(querytag)[1]
	if statsitem then statsitem.Value += amount end 
	if profileitem and backtool then 
		if packtool and startool then
			local newamount = packtool:GetAttribute("Amount") + amount
			packtool:SetAttribute("Amount", newamount) packtool.Name = itemname .. " x " .. newamount
			startool:SetAttribute("Amount", newamount) startool.Name = itemname .. " x " .. newamount
		else local tool = backtool:Clone() tool:SetAttribute("Amount", amount)
			tool.Name = itemname .. " x " .. amount tool.Parent = pack tool:Clone().Parent = start
		end	end
    if profileitem then profile[itemname] += amount return
    else profile[itemname] = amount
	end end
function DataStoreWrapper.removeitem(player, itemname, amount, tabletolookinto)
		local profile = profiles[player.UserId]
		local stats = player.stats
		local leaderstats = player.leaderstats
		local statsitem = stats:FindFirstChild(itemname) or leaderstats:FindFirstChild(itemname)
		local proftable = profile[tabletolookinto]
		local profileitem = profile[itemname] or proftable[itemname]
		local tool = game.ServerStorage.Tools:FindFirstChild(itemname)
		local querytag = '[$ToolName = "'..itemname..'"]'
		local packtool = player.Backpack:QueryDescendants(querytag)[1] or player.Character:FindFirstChildWhichIsA("Tool")
		if packtool and packtool:GetAttribute("ToolName") ~= itemname then packtool = nil end
	    local startool = player.StarterGear:QueryDescendants(querytag)[1]
		if statsitem then statsitem.Value -= amount end
		if profileitem and tool and packtool then
		local newamount = packtool:GetAttribute("Amount") - amount print(newamount) print(newamount)
		if newamount >= 1 then packtool:SetAttribute("Amount", newamount) packtool.Name = itemname .. " x " .. newamount
		startool:SetAttribute("Amount", newamount) startool.Name = itemname .. " x " .. newamount
		else startool:Destroy() packtool:Destroy() profile[itemname] = 0 return end end
		if profileitem then profile[itemname] -= amount return 	
		end
	end
