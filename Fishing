local f = require(game.ReplicatedStorage.Modules.Commonfuncs).GetMods()
workspace:WaitForChild("Bench")
for _, bench in game.CollectionService:GetTagged("FishBench") do
local seat = bench:WaitForChild("Seat")
local storage = game.ServerStorage
local rodCosmetic = bench:WaitForChild("FishingRod")
local seated
local rod, hook, att, op, iscast, ready, hascaught, timeCasted
local function getFish(timeC, player)
	timeC = math.max(timeC, 1)
	local fishcount = 0
	local profile = f.Profiles.getprofile(player.UserId)
	local rod = profile["Fishing Rod"] or 0
	local luckMulti = f.Info.fishing.rods[f.Info.upgradeorders["Fishing Rod"][rod].name].luck
	local luckFactor = timeC^0.2 * luckMulti
	if profile["Achievsets"]["Fishing"] and profile["Achievsets"]["Fishing"]["easy"] then luckFactor *= 1.25 end
	local luckNumber = math.floor((1 - 1/luckFactor) * 100)
	local random = math.random(luckNumber, 100)
	local chosenFish
	for _, fish in f.Info.fishing.fishorder do
		local info = f.Info.fishing.fish[fish]
		fishcount += info.chance
		if random <= fishcount then
			chosenFish = fish break
		end
	end
	print("You caught a..", chosenFish)
	if chosenFish == "Salmon" then f.Profiles.progAchieve(player, {Cat = "Fishing", Diff = "easy", Index = 1}, 1) end
	f.Profiles.progAchieve(player, {Cat = "Fishing", Diff = "easy", Index = 3}, 1)
	if timeC < 6 then f.Profiles.awardAchievement(player, {Skill = "Fishing", Diff = "easy", Index = 2}) end
	return chosenFish
end
