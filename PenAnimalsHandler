local function followPath(destination, character)
	local humanoid = character:WaitForChild("Humanoid")
	local success, errorMessage = pcall(function()
		return path:ComputeAsync(character.Position, destination)
	end)
	local waypoints
	local nextWaypointIndex
	local reachedConnection
	local blockedConnection
	if success and path.Status == Enum.PathStatus.Success then
		waypoints = path:GetWaypoints()
		blockedConnection = path.Blocked:Connect(function(blockedWaypointIndex)
			if blockedWaypointIndex >= nextWaypointIndex then
				blockedConnection:Disconnect()
				followPath(destination, character)
			end
		end)
		if not reachedConnection then
			reachedConnection = humanoid.MoveToFinished:Connect(function(reached)
				if reached and nextWaypointIndex < #waypoints then
					-- Increase waypoint index and move to next waypoint
					nextWaypointIndex += 1
					humanoid:MoveTo(waypoints[nextWaypointIndex].Position)
				else
					reachedConnection:Disconnect()
					blockedConnection:Disconnect()
				end
			end)
		end
		nextWaypointIndex = 2
		local nwp = waypoints[nextWaypointIndex]
		if not nwp then return end
		local pos = Vector3.new(nwp.Position.X, 7, nwp.Position.Z)
		game.TweenService:Create(character, TweenInfo.new(1.2/(#waypoints)), {Position = pos}):Play()
		--humanoid:MoveTo(pos)
	else
		warn("Path not computed!", errorMessage,path)
	end
end
