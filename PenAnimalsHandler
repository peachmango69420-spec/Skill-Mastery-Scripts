local function getTotalFood(animalname)
	local profile = f.SafeGet()
	local total = 0
	for _, info in (profile["Animals"][animalname] or {}) do
	if not info["Dead"] then
		local food = farminfo.Animals[animalname].Eat
		if info["Defects"] and info["Defects"]["Glutton"] then
			total += food
		end total += food
	end
	end
	return total
end
