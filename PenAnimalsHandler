local function getTimeStamp(number)
	if number < 60 then return number.."s"
	elseif number < 3600 then return number//60 .."m "..(number%60).."s"
	elseif number < 86400 then return number//3600 .."h "..(number%3600)//60 .. "m ".. number%60 .. "s"
	elseif number >= 86400 then return number//86400 .."d "..(number%86400)//3600 .."h ".. (number%3600)//60 .."m "..number%60 .."s" end
end
